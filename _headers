# Security headers for static hosting (example for Netlify or similar)
[[headers]]
  for = "/*"
  [headers]
    X-Frame-Options = "DENY"
    X-Content-Type-Options = "nosniff"
    Referrer-Policy = "strict-origin-when-cross-origin"
    Content-Security-Policy = "default-src 'self'; img-src * data:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; object-src 'none'"
    Strict-Transport-Security = "max-age=63072000; includeSubDomains; preload"
